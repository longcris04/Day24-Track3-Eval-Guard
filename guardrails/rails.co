# ── Self-check rails (LLM-based, dùng prompt trong config.yml) ─────────────────
# Cách tiếp cận ổn định với model OpenRouter: để LLM trả lời Yes/No có chặn không.
#
# QUAN TRỌNG: KHÔNG định nghĩa các `define user ask ...` ở đây. Nếu có, NeMo sẽ dùng chúng
# làm canonical intent cho bước generate_user_intent và rất dễ phân loại nhầm câu hỏi HR
# hợp lệ thành "ask pii request" → decline oan. Việc chặn đã do self_check_input lo.

define bot refuse to respond
  "Xin lỗi, tôi không thể trả lời yêu cầu này. Tôi chỉ hỗ trợ các câu hỏi về chính sách nhân sự công ty (nghỉ phép, lương thưởng, bảo hiểm, quy trình HR)."

define flow self check input
  $allowed = execute self_check_input
  if not $allowed
    bot refuse to respond
    stop

define flow self check output
  $allowed = execute self_check_output
  if not $allowed
    bot refuse to respond
    stop
